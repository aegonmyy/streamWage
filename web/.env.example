# Optional: override WalletConnect Cloud project id (defaults to repo value in lib/wagmi.ts)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Supabase — used for worker enrollment tracking (so workers auto-discover their payrolls)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Payroll factory used to discover and deploy tenant payroll contracts.
NEXT_PUBLIC_PAYROLL_FACTORY_ADDRESS=

# Chain id hosting the factory and payroll contracts. Hoodi is 560048.
NEXT_PUBLIC_PAYROLL_CHAIN_ID=560048

# Optional: override Hoodi RPC used by wagmi (defaults to wagmi's hoodi rpcUrls).
NEXT_PUBLIC_HOODI_RPC_URL=

# Block number where the payroll contract was deployed. Set this in production so
# admin event indexing doesn't scan from genesis.
NEXT_PUBLIC_PAYROLL_FROM_BLOCK=0

# Worker dashboards only scan recent logs for activity. Keep this small on free RPCs.
NEXT_PUBLIC_PAYROLL_EVENT_LOOKBACK_BLOCKS=500
