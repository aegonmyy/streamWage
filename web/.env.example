# Optional: override WalletConnect Cloud project id (defaults to repo value in lib/wagmi.ts)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Payroll contract used for role checks.
NEXT_PUBLIC_PAYROLL_CONTRACT_ADDRESS=

# Chain id hosting the payroll contract. Defaults to 31337 for local Anvil.
NEXT_PUBLIC_PAYROLL_CHAIN_ID=31337

# Optional: override Hoodi RPC used by wagmi (defaults to wagmi's hoodi rpcUrls).
NEXT_PUBLIC_HOODI_RPC_URL=

# Block number where the payroll contract was deployed. Set this in production so
# admin event indexing doesn't scan from genesis.
NEXT_PUBLIC_PAYROLL_FROM_BLOCK=0
